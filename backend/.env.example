# Database URL - Use local SQLite or SQLite Cloud
# Local SQLite: DATABASE_URL=rental_shop.db
# SQLite Cloud: DATABASE_URL=sqlitecloud://host:port/database?apikey=your-api-key
DATABASE_URL=rental_shop.db

GEMINI_API_KEY=your-gemini-api-key-here
CORS_ORIGINS=["http://localhost:5173"]
SECRET_KEY=generate-a-new-secret-key-in-production
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=100
CSRF_ENABLED=true
JWT_ENABLED=true

# Production overrides (uncomment for deployment)
# DATABASE_URL=sqlitecloud://crgeozpbdk.g5.sqlite.cloud:8860/auth.sqlitecloud?apikey=your-api-key
# SECRET_KEY=generate-a-new-secret-key-in-production
# CORS_ORIGINS=["https://yourdomain.com"]
